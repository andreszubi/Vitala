<!--
  Demo build: no special entitlements required.
  HealthKit reads/writes will return "not authorized" at runtime, but the app
  will launch on any simulator without provisioning headaches. To re-enable
  HealthKit on a real device with a paid developer account, restore:

      <key>com.apple.developer.healthkit</key>
      <true/>
-->
